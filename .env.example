# Copier en .env et renseigner les vraies valeurs (jamais commiter .env)
PORT=3000
LLM_PROVIDER_ORDER=gemini,anthropic,openai

# Security: API Key to protect endpoints from abuse
# Generate with: openssl rand -hex 32
API_KEY=your-secret-api-key-here

DATABASE_URL=postgresql://user:password@host:5432/db?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/db
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=fake-publishable-key
SUPABASE_SECRET_KEY=fake-secret-key
SUPABASE_JWKS_URL=https://xxxxx.supabase.co/auth/v1/.well-known/jwks.json

YOUTUBE_API_KEY=fake-youtube-key
YOUTUBE_CHANNEL_ID=UC_wmzB9ziSW5KbZxyDfZV_w

GOOGLE_API_KEY=fake-gemini-key
ANTHROPIC_API_KEY=fake-anthropic-key
OPENAI_API_KEY=fake-openai-key
